{
  "name": "personal-knowledge-asset-os",
  "type": "module",
  "version": "0.1.0",
  "description": "Personal Knowledge Asset OS — 统一管理笔记、简历、项目、演示文稿与语义图谱的知识基础设施",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:assets && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "astro preview",
    "astro": "astro",
    "build:resume": "node scripts/build-resume.js",
    "build:decks": "node scripts/build-decks.js",
    "build:semantic": "node scripts/build-semantic-graph.js",
    "build:assets": "node scripts/build-assets.js",
    "validate:prd": "node scripts/validate-prd.js",
    "validate:pipeline": "node scripts/validate-pipeline.js",
    "test": "node --test tests/*.test.js",
    "lint": "astro check",
    "verify": "npm run lint && npm run validate:prd && npm run validate:pipeline && npm test && npm run build",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs personal-blog-dev personal-blog-preview --lines 80 --nostream",
    "pm2:delete": "pm2 delete personal-blog-dev personal-blog-preview"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.10.1",
    "lz-string": "^1.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.3.4",
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3"
  }
}
