---
import { readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const pathname = Astro.url.pathname;

// 动态读取 resume.json 中的全局元数据
let siteUrl = 'https://caolei.net';
let siteDescription = '个人知识资产操作系统 - 聚合笔记、简历、项目与演示文稿';
let authorName = '曹磊';

const resumePath = join(process.cwd(), 'public/assets/resume.json');
if (existsSync(resumePath)) {
  try {
    const resume = JSON.parse(readFileSync(resumePath, 'utf-8'));
    if (resume?.basics) {
      if (resume.basics.url) siteUrl = resume.basics.url.replace(/\/$/, '');
      if (resume.basics.name) authorName = resume.basics.name;
      if (resume.basics.summary) siteDescription = resume.basics.summary;
    }
  } catch (e) {
    // ignore
  }
}

const pageTitle = title ? `${title} — ${authorName}的知识系统` : `${authorName}的个人知识资产操作系统`;
const pageDescription = description || siteDescription;
const canonicalUrl = `${siteUrl}${pathname}`;

const isActive = (path: string) => {
  if (path === '/') {
    return pathname === '/' || pathname === '/index.html';
  }
  return pathname === path || pathname.startsWith(path + '/');
};

const navItems = [
  { label: '工作台', href: '/' },
  { label: '搜索', href: '/search' },
  { label: '笔记', href: '/notes' },
  { label: '项目', href: '/projects' },
  { label: '文稿', href: '/decks' },
  { label: '简历', href: '/resume' },
  { label: '实验室', href: '/lab/graph' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Primary Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:site_name" content={`${authorName}的知识系统`} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDescription} />
  </head>
  <body class="bg-surface-50 text-surface-900 min-h-screen flex flex-col">
    <header class="sticky top-0 z-40 w-full border-b border-surface-200 bg-white/80 backdrop-blur">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between gap-4">
        <a href="/" class="font-bold text-base tracking-tight text-surface-900 hover:text-accent shrink-0">
          PK Asset OS
        </a>
        <nav class="flex items-center gap-1 sm:gap-2 overflow-x-auto scrollbar-none py-1 -mr-6 pr-6 sm:mr-0 sm:pr-0">
          {navItems.map((item) => {
            const active = isActive(item.href);
            return (
              <a
                href={item.href}
                class={`text-xs sm:text-sm font-medium px-2.5 py-1.5 rounded-md transition-colors shrink-0 ${
                  active
                    ? 'text-accent bg-blue-50 font-semibold'
                    : 'text-surface-600 hover:text-surface-900 hover:bg-surface-100'
                }`}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-10 w-full flex-grow">
      <slot />
    </main>

    <footer class="border-t border-surface-200 bg-white py-6 mt-auto">
      <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-surface-400 font-mono">
        <p>Personal Knowledge Asset OS v0.1.0</p>
        <div class="flex items-center gap-3">
          <a href="/rss.xml" class="hover:text-accent flex items-center gap-0.5">RSS Feed <span>↗</span></a>
          <span class="text-surface-200">|</span>
          <a href="/atom.xml" class="hover:text-accent flex items-center gap-0.5">Atom Feed <span>↗</span></a>
        </div>
        <p>© 2026 Personal Knowledge Asset OS. All assets managed locally.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* 隐藏滚动条 */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
