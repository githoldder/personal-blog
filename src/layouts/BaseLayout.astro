---
import { readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import SiteMark from '../components/SiteMark.astro';
import SoftCursor from '../components/SoftCursor.astro';
import { styleVarsForTheme, type ThemeKey } from '../lib/themeTaxonomy';

interface Props {
  title: string;
  description?: string;
  theme?: ThemeKey;
}

const { title, description, theme = 'default' } = Astro.props;
const pathname = Astro.url.pathname;

// 动态读取 resume.json 中的全局元数据
let siteUrl = 'https://caolei.net';
let siteDescription = '个人知识资产操作系统 - 聚合笔记、简历、项目与演示文稿';
const publicHandle = 'githoldder';

const resumePath = join(process.cwd(), 'public/assets/resume.json');
if (existsSync(resumePath)) {
  try {
    const resume = JSON.parse(readFileSync(resumePath, 'utf-8'));
    if (resume?.basics) {
      if (resume.basics.url) siteUrl = resume.basics.url.replace(/\/$/, '');
      if (resume.basics.summary) siteDescription = resume.basics.summary;
    }
  } catch (e) {
    // ignore
  }
}

const pageTitle = title ? `${title} — ${publicHandle} knowledge OS` : `${publicHandle} knowledge OS`;
const pageDescription = description || siteDescription;
const canonicalUrl = `${siteUrl}${pathname}`;
const themeStyle = styleVarsForTheme(theme);

const isActive = (path: string) => {
  if (path === '/') {
    return pathname === '/' || pathname === '/index.html';
  }
  return pathname === path || pathname.startsWith(path + '/');
};

const navItems = [
  { label: '工作台', href: '/' },
  { label: '笔记', href: '/notes' },
  { label: '项目', href: '/projects' },
  { label: '图谱', href: '/lab/graph' },
  { label: '图书馆', href: '/library' },
  { label: '简历', href: '/resume' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Primary Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:site_name" content={`${publicHandle} knowledge OS`} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDescription} />
  </head>
  <body class="bg-surface-50 text-surface-900 min-h-screen flex flex-col" style={themeStyle}>
    <header class="site-header sticky top-0 z-40 w-full border-b border-slate-200/60 bg-[#fbf8f1]/88 backdrop-blur">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between gap-4">
        <SiteMark />
        <nav class="site-nav flex items-center gap-1 overflow-x-auto scrollbar-none py-1 -mr-6 pr-6 sm:mr-0 sm:pr-0" aria-label="Primary">
          {navItems.map((item) => {
            const active = isActive(item.href);
            return (
              <a
                href={item.href}
                data-nav-link
                aria-current={active ? 'page' : undefined}
                class={`site-nav__link text-xs sm:text-sm font-sans font-bold px-2.5 py-1.5 transition-colors shrink-0 ${
                  active
                    ? 'site-nav__link--active text-rose-700 font-bold'
                    : 'text-slate-600 hover:text-rose-700'
                }`}
              >
                {item.label}
              </a>
            );
          })}
          <a
            href="/search"
            class="site-nav__utility text-xs sm:text-sm font-sans font-bold px-2 py-1.5 transition-colors shrink-0 text-slate-500 hover:text-rose-700"
            aria-label="搜索"
            title="搜索"
            data-utility-action
          >
            ⌕
          </a>
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-8 md:py-10 w-full flex-grow">
      <slot />
    </main>

    <footer class="border-t border-slate-200/60 bg-[#fbf8f1]/70 py-6 mt-auto">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-surface-400 font-mono">
        <p>Personal Knowledge Asset OS v0.1.0</p>
        <div class="flex items-center gap-3">
          <a href="/rss.xml" class="hover:text-accent flex items-center gap-0.5">RSS Feed <span>↗</span></a>
          <span class="text-surface-200">|</span>
          <a href="/atom.xml" class="hover:text-accent flex items-center gap-0.5">Atom Feed <span>↗</span></a>
        </div>
        <p>© 2026 Personal Knowledge Asset OS. All assets managed locally.</p>
      </div>
    </footer>
    <SoftCursor />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* 隐藏滚动条 */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* 禅宗 Zen Mode 沉浸式阅读样式屏蔽 */
  body.zen-reading header, body.zen-reading footer {
    display: none !important;
  }
  body.zen-reading main {
    padding-top: 2rem !important;
    padding-bottom: 2rem !important;
    max-width: 75ch !important;
  }

  .obsidian-trigger {
    margin: 0 0 2rem !important;
    padding: 0 !important;
    border: 0 !important;
    background: transparent !important;
    display: block !important;
    font-size: 10px !important;
    color: rgb(148 163 184) !important;
    font-family: 'JetBrains Mono', 'Fira Code', monospace !important;
  }
  .obsidian-trigger a[href^="obsidian://"] {
    display: none !important;
  }
  .obsidian-trigger span {
    color: rgb(148 163 184) !important;
  }
</style>
