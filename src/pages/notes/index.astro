---
import BaseLayout from '../../layouts/BaseLayout.astro';

// TODO: 实现内容集合读取
// import { getCollection } from 'astro:content';
// const notes = await getCollection('notes');
const notes = [
  { slug: 'personal-knowledge-asset-os', title: 'Personal Knowledge Asset OS 架构设计', date: '2026-06-26', tags: ['架构', '知识管理'] },
];
---

<BaseLayout title="笔记 — Personal Knowledge Asset OS">
  <main class="max-w-4xl mx-auto px-6 py-12">
    <header class="mb-8">
      <a href="/" class="text-sm text-surface-500 hover:text-accent transition-colors">← 返回工作台</a>
      <h1 class="text-2xl font-bold mt-4">笔记</h1>
      <p class="text-surface-500 mt-1">
        知识碎片与思考记录。来源: <code>content/notes/</code>
      </p>
    </header>

    <section>
      <div class="space-y-3">
        {notes.map((note) => (
          <a href={`/notes/${note.slug}`} class="workspace-card block group">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="font-medium group-hover:text-accent transition-colors">
                  {note.title}
                </h3>
                <div class="flex items-center gap-3 mt-1 text-sm text-surface-500">
                  <time>{note.date}</time>
                  <div class="flex gap-1">
                    {note.tags.map((tag) => (
                      <span class="status-tag status-tag--todo">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
              <span class="text-surface-400 group-hover:text-accent transition-colors">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
