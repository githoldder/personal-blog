---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const notes = (await getCollection('notes'))
  .map((entry) => ({
    id: entry.id,
    slug: entry.data.slug ?? entry.id,
    title: entry.data.title,
    date: entry.data.date,
    tags: entry.data.tags,
    status: entry.data.status
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const formatDate = (date: Date) => date.toISOString().slice(0, 10);
---

<BaseLayout title="笔记 — Personal Knowledge Asset OS">
  <header class="mb-8">
    <h1 class="text-2xl font-bold">笔记</h1>
    <p class="text-surface-500 mt-1">
      知识碎片与思考记录。来源: <code>content/notes/</code>
    </p>
  </header>

  <section>
    {notes.length === 0 ? (
      <div class="workspace-card p-8 text-center text-surface-500">
        <p>暂无笔记。请在 <code>content/notes/</code> 中添加 Markdown 文件。</p>
      </div>
    ) : (
      <div class="space-y-3">
        {notes.map((note) => (
          <article class="workspace-card block" id={note.slug}>
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
              <div>
                <h3 class="font-medium text-surface-900">
                  {note.title}
                </h3>
                <div class="flex flex-wrap items-center gap-3 mt-2 text-sm text-surface-500">
                  <time datetime={formatDate(note.date)}>{formatDate(note.date)}</time>
                  <span class="status-tag status-tag--todo">{note.status}</span>
                  <div class="flex flex-wrap gap-1">
                    {note.tags.map((tag) => (
                      <span class="status-tag status-tag--todo">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
              <code class="text-xs text-surface-400 shrink-0">{note.slug}</code>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
