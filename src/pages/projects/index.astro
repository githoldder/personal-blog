---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CoordinateAxis from '../../components/CoordinateAxis.astro';

// 获取所有项目并按权重及时间倒序排序
const pinnedOrder = [
  'lingobridge',
  'school-gtd-dashboard',
  'springboot-lgg',
  'file-processor-assistant',
  'personal-blog',
  'darwin-skill'
];

const projects = (await getCollection('projects'))
  .filter((entry) => {
    const status = entry.data.status;
    const normalized = status ? String(status).toLowerCase().trim() : undefined;
    return normalized !== 'archived'; // 仅排除归档
  })
  .map((entry) => ({
    id: entry.id,
    slug: entry.data.slug ?? entry.id,
    title: entry.data.title.replace(/曹磊/g, 'githoldder'),
    description: entry.data.description.replace(/曹磊/g, 'caolei'),
    status: entry.data.status,
    date: entry.data.date,
    tech: entry.data.tech,
    github: entry.data.github || `https://github.com/githoldder/${entry.data.slug ?? entry.id}`
  }))
  .sort((a, b) => {
    const idxA = pinnedOrder.indexOf(a.slug);
    const idxB = pinnedOrder.indexOf(b.slug);
    
    if (idxA !== -1 && idxB !== -1) {
      return idxA - idxB;
    }
    if (idxA !== -1) return -1;
    if (idxB !== -1) return 1;
    
    return b.date.getTime() - a.date.getTime();
  });

const formatDate = (date: Date) => date.toISOString().slice(0, 7);

const statusLabels = {
  todo: '计划中',
  in_progress: '进行中',
  done: '已上线',
  archived: '已归档'
};

const statusClasses = {
  todo: 'bg-slate-50 text-slate-500 border-slate-200',
  in_progress: 'bg-rose-50 text-rose-700 border-rose-200 animate-pulse',
  done: 'bg-green-50 text-green-700 border-green-200',
  archived: 'bg-slate-100 text-slate-400 border-slate-200'
};

const allTechs = Array.from(new Set(projects.flatMap(p => p.tech))).slice(0, 8);
---

<BaseLayout title="项目时间线 — Personal Knowledge Asset OS">
  
  <header class="pb-8 pt-6 select-none max-w-4xl">
    <div class="inline-flex items-center gap-1.5 px-2 py-0.5 text-[9px] font-mono font-bold tracking-widest text-rose-800 bg-rose-50 border border-rose-200/50 rounded uppercase mb-4">
      PROJECT LIFECYCLE TIMELINE
    </div>
    <h1 class="text-3xl md:text-4xl font-serif font-bold text-slate-900 leading-tight">🌿 项目研发轨迹</h1>
    <p class="mt-3 font-serif text-slate-650 leading-relaxed text-sm md:text-base max-w-3xl">
      这是我参与的科研、商业实践与自主创业项目的进展追踪。通过将每个项目的生命周期映射到统一的知识管理系统，实现工程产出与学术思考的闭环。点击项目卡片可唤起详情说明及 GitHub 仓库。
    </p>

    <!-- Filters HUD (Amelia Style Coordinate control) -->
    <div class="mt-6 border-t border-slate-200/60 pt-4 text-xs space-y-3 font-mono">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-slate-400 font-bold uppercase text-[9px]">Status filter:</span>
        <button class="px-2 py-0.5 rounded border border-rose-500 bg-rose-900 text-white font-mono scale-[0.98]">ALL</button>
        {Object.entries(statusLabels).map(([key, label]) => (
          <button class="px-2 py-0.5 rounded border border-slate-200 hover:border-rose-400 font-mono text-slate-600 bg-white transition-colors">{label}</button>
        ))}
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-slate-400 font-bold uppercase text-[9px]">Tech cluster:</span>
        <button class="px-2 py-0.5 rounded border border-rose-500 bg-rose-900 text-white font-mono scale-[0.98]">ALL</button>
        {allTechs.map((tech) => (
          <button class="px-2 py-0.5 rounded border border-slate-200 hover:border-rose-400 font-mono text-slate-500 bg-white transition-colors">#{tech}</button>
        ))}
      </div>
    </div>
  </header>

  <!-- Asymmetric Timeline Layout -->
  <section class="relative border-l border-dashed border-slate-300/80 ml-3 sm:ml-4 py-4 space-y-12">
    {projects.length === 0 ? (
      <div class="py-12 text-center text-slate-400 font-serif border border-slate-200/50 rounded-md">
        <p>暂无活跃项目。请在 <code>content/projects/</code> 中添加 Markdown 项目文档。</p>
      </div>
    ) : (
      projects.map((project) => (
        <article 
          class="relative group pl-6 sm:pl-8 project-card-trigger cursor-pointer transition-transform active:scale-[0.99]"
          data-project-title={project.title}
          data-project-desc={project.description}
          data-project-date={formatDate(project.date)}
          data-project-status={project.status}
          data-project-status-text={statusLabels[project.status]}
          data-project-slug={project.slug}
          data-project-github={project.github}
          role="button"
          tabindex="0"
          aria-label={`查看项目 ${project.title} 详情`}
        >
          
          <!-- Coordinate Node Dot -->
          <div class="absolute -left-[9px] top-1.5 w-4 h-4 rounded-full border-2 border-white bg-rose-600 shadow-sm group-hover:scale-125 transition-transform duration-150 flex items-center justify-center">
            <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
          </div>

          <div class="space-y-4">
            <!-- Header Axis line -->
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between border-b border-slate-100 pb-2 gap-2">
              <div class="flex flex-wrap items-center gap-3">
                <h3 class="text-lg md:text-xl font-serif font-bold text-slate-900 group-hover:text-rose-700 transition-colors">
                  {project.title}
                </h3>
                <span class={`status-tag ${statusClasses[project.status]}`}>
                  {statusLabels[project.status]}
                </span>
              </div>
              <div class="text-slate-400 font-mono text-[9px] font-bold">
                TIME_COORD: <span class="text-rose-700">{formatDate(project.date)}</span>
              </div>
            </div>

            <!-- Content Area split -->
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
              
              <div class="md:col-span-8 space-y-3">
                <p class="text-sm md:text-base text-slate-600 leading-relaxed font-serif line-clamp-3">
                  {project.description}
                </p>
                <div class="flex flex-wrap items-center gap-1.5 pt-2">
                  <span class="text-[9px] font-mono font-bold text-slate-400 uppercase">ENGINE:</span>
                  {project.tech.map((item) => (
                    <span class="tech-tag hover:border-rose-400 transition-colors">
                      {item}
                    </span>
                  ))}
                </div>
              </div>

              <!-- Amelia style coordinate detail panel -->
              <div class="md:col-span-4 font-mono text-[9px] text-slate-500 space-y-1.5 bg-slate-50/50 border border-slate-200/50 p-4 rounded-md">
                <div class="flex justify-between">
                  <span>ASSET LAYER:</span>
                  <span class="text-slate-700 font-bold uppercase">PROJECT</span>
                </div>
                <div class="flex justify-between">
                  <span>METADATA ID:</span>
                  <span class="text-slate-700 font-bold">project:{project.slug}</span>
                </div>
                <div class="flex justify-between border-t border-slate-200/50 pt-1.5 mt-1.5">
                  <span>RELATION MAP:</span>
                  <a href={`/lab/graph?focus=project:${project.slug}`} class="text-rose-700 font-bold hover:underline" onclick="event.stopPropagation()">LOCATE NODE ↗</a>
                </div>
              </div>

            </div>
          </div>
        </article>
      ))
    )}
  </section>

  <!-- Project Detail Dialogue Modal overlay -->
  <dialog id="project-dialog" class="backdrop:bg-black/30 bg-[#FCFAF7] border border-slate-200/80 rounded-md max-w-md w-full p-6 shadow-2xl font-sans text-xs focus:outline-none select-none">
    <div class="space-y-5">
      <div class="flex items-center justify-between border-b border-slate-200/60 pb-3">
        <h3 id="modal-title" class="text-base font-serif font-bold text-slate-900">项目标题</h3>
        <span id="modal-status" class="px-2 py-0.5 rounded text-[9px] font-mono font-bold uppercase border">状态</span>
      </div>
      
      <div class="space-y-3 font-serif leading-relaxed text-slate-700 text-sm select-text">
        <p id="modal-desc" class="whitespace-pre-wrap">项目详情简述...</p>
      </div>

      <div class="font-mono text-[9px] text-slate-400 border-t border-slate-200/40 pt-3 flex justify-between select-none">
        <span>TIME_COORD: <span id="modal-date" class="text-rose-700 font-bold">2026-06</span></span>
        <span>METADATA ID: <span id="modal-id" class="text-slate-700 font-bold">project:slug</span></span>
      </div>

      <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-200/50">
        <button id="modal-close" class="px-3.5 py-1.5 bg-white border border-slate-200 text-slate-600 font-mono font-bold rounded hover:bg-slate-50 transition-colors uppercase">
          关闭
        </button>
        <a id="modal-detail-link" href="#" class="px-3.5 py-1.5 bg-rose-50 border border-rose-200 text-rose-800 font-mono font-bold rounded hover:bg-rose-100/60 transition-colors uppercase">
          在线文档 ➔
        </a>
        <a id="modal-github-link" href="#" target="_blank" class="px-3.5 py-1.5 bg-slate-900 hover:bg-black text-white font-mono font-bold rounded transition-colors uppercase inline-flex items-center gap-1">
          🐙 GitHub ↗
        </a>
      </div>
    </div>
  </dialog>
</BaseLayout>

<script>
  // 原生 Dialogue Modal 控制逻辑
  const dialog = document.getElementById('project-dialog') as HTMLDialogElement | null;
  const cards = document.querySelectorAll('.project-card-trigger');
  
  const mTitle = document.getElementById('modal-title');
  const mStatus = document.getElementById('modal-status');
  const mDesc = document.getElementById('modal-desc');
  const mDate = document.getElementById('modal-date');
  const mId = document.getElementById('modal-id');
  const mClose = document.getElementById('modal-close');
  const mDetailLink = document.getElementById('modal-detail-link') as HTMLAnchorElement | null;
  const mGithubLink = document.getElementById('modal-github-link') as HTMLAnchorElement | null;

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const title = card.getAttribute('data-project-title') || '';
      const desc = card.getAttribute('data-project-desc') || '';
      const date = card.getAttribute('data-project-date') || '';
      const status = card.getAttribute('data-project-status') || '';
      const statusText = card.getAttribute('data-project-status-text') || '';
      const slug = card.getAttribute('data-project-slug') || '';
      const github = card.getAttribute('data-project-github') || '';

      if (mTitle) mTitle.innerText = title;
      if (mStatus) {
        mStatus.innerText = statusText;
        mStatus.className = `px-2 py-0.5 rounded text-[9px] font-mono font-bold uppercase border ${
          status === 'done' ? 'bg-green-50 text-green-700 border-green-200' :
          status === 'in_progress' ? 'bg-rose-50 text-rose-700 border-rose-200' :
          'bg-slate-50 text-slate-500 border-slate-200'
        }`;
      }
      if (mDesc) mDesc.innerText = desc;
      if (mDate) mDate.innerText = date;
      if (mId) mId.innerText = `project:${slug}`;
      if (mDetailLink) mDetailLink.href = `/projects/${slug}/`;
      if (mGithubLink) mGithubLink.href = github || `https://github.com/githoldder/${slug}`;

      dialog?.showModal();
    });

    // 键盘支持
    card.addEventListener('keydown', (e) => {
      const keyboardEvent = e as KeyboardEvent;
      if (keyboardEvent.key === 'Enter' || keyboardEvent.key === ' ') {
        e.preventDefault();
        (card as HTMLElement).click();
      }
    });
  });

  mClose?.addEventListener('click', () => {
    dialog?.close();
  });

  // 点击背景自动关闭对话框
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) {
      dialog.close();
    }
  });
</script>
