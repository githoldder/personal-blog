---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="全局搜索 — Personal Knowledge Asset OS">
  <header class="mb-8">
    <h1 class="text-2xl font-bold">全局搜索</h1>
    <p class="text-surface-500 mt-1">
      在本地以极简工作台方式，跨笔记、项目、文稿和简历进行秒级模糊检索。
    </p>
  </header>

  <div class="space-y-6">
    <!-- 搜索输入框 -->
    <div class="relative">
      <input
        type="text"
        id="search-input"
        placeholder="输入关键词、标签（如: Astro）或正文词汇进行搜索..."
        class="w-full bg-white border border-surface-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-accent transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.01)]"
        autofocus
      />
      <div id="search-spinner" class="hidden absolute right-4 top-3 text-surface-400 text-xs font-mono">
        加载索引中...
      </div>
    </div>

    <!-- 筛选页签 -->
    <div class="flex flex-wrap gap-2 border-b border-surface-200 pb-4" id="filter-tabs">
      <button class="px-3 py-1.5 text-xs font-medium rounded-md transition-colors bg-accent text-white" data-type="all">
        全部
      </button>
      <button class="px-3 py-1.5 text-xs font-medium rounded-md transition-colors bg-white border border-surface-200 text-surface-600 hover:bg-surface-50" data-type="note">
        笔记
      </button>
      <button class="px-3 py-1.5 text-xs font-medium rounded-md transition-colors bg-white border border-surface-200 text-surface-600 hover:bg-surface-50" data-type="project">
        项目
      </button>
      <button class="px-3 py-1.5 text-xs font-medium rounded-md transition-colors bg-white border border-surface-200 text-surface-600 hover:bg-surface-50" data-type="deck">
        文稿
      </button>
      <button class="px-3 py-1.5 text-xs font-medium rounded-md transition-colors bg-white border border-surface-200 text-surface-600 hover:bg-surface-50" data-type="resume">
        简历
      </button>
    </div>

    <!-- 结果统计 -->
    <div class="text-xs text-surface-400 font-mono flex items-center justify-between" id="search-meta">
      <span id="results-count">正在初始化本地索引...</span>
    </div>

    <!-- 结果展示 -->
    <div id="results-container" class="space-y-4">
      <!-- 动态插入结果 -->
    </div>
  </div>

  <!-- 客户端 JS 逻辑 -->
  <script is:inline>
    let searchIndex = [];
    let currentType = 'all';

    const searchInput = document.getElementById('search-input');
    const resultsContainer = document.getElementById('results-container');
    const resultsCount = document.getElementById('results-count');
    const spinner = document.getElementById('search-spinner');

    async function init() {
      if (spinner) spinner.classList.remove('hidden');
      try {
        const res = await fetch('/assets/search-index.json');
        searchIndex = await res.json();
        resultsCount.textContent = '输入关键词开始搜索';
      } catch (e) {
        console.error('Failed to load search index:', e);
        resultsCount.textContent = '加载搜索索引失败，请重新打包资产。';
      } finally {
        if (spinner) spinner.classList.add('hidden');
      }

      // 处理可能后退或残留的输入框值
      if (searchInput.value.trim()) {
        performSearch();
      }
    }

    const tabs = document.querySelectorAll('#filter-tabs button');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => {
          t.classList.remove('bg-accent', 'text-white');
          t.classList.add('bg-white', 'border', 'border-surface-200', 'text-surface-600', 'hover:bg-surface-50');
        });
        tab.classList.add('bg-accent', 'text-white');
        tab.classList.remove('bg-white', 'border', 'border-surface-200', 'text-surface-600', 'hover:bg-surface-50');
        
        currentType = tab.getAttribute('data-type');
        performSearch();
      });
    });

    searchInput.addEventListener('input', performSearch);

    function performSearch() {
      const query = searchInput.value.trim().toLowerCase();
      if (!query) {
        resultsContainer.innerHTML = '';
        resultsCount.textContent = '输入关键词开始搜索';
        return;
      }

      const terms = query.split(/\s+/).filter(Boolean);
      if (terms.length === 0) {
        resultsContainer.innerHTML = '';
        resultsCount.textContent = '输入关键词开始搜索';
        return;
      }

      // 过滤匹配
      let matched = searchIndex.filter(item => {
        if (currentType !== 'all' && item.type !== currentType) {
          return false;
        }

        const titleLower = item.title.toLowerCase();
        const tagsLower = item.tags.map(t => t.toLowerCase()).join(' ');
        const summaryLower = item.summary.toLowerCase();
        const textLower = item.text.toLowerCase();

        // AND 逻辑：必须包含所有子项关键词
        return terms.every(term =>
          titleLower.includes(term) ||
          tagsLower.includes(term) ||
          summaryLower.includes(term) ||
          textLower.includes(term)
        );
      });

      // 排序计分
      matched = matched.map(item => {
        let score = 0;
        const titleLower = item.title.toLowerCase();
        const tagsLower = item.tags.map(t => t.toLowerCase()).join(' ');

        if (titleLower === query) score += 100;
        else if (titleLower.includes(query)) score += 50;
        else if (terms.every(t => titleLower.includes(t))) score += 30;

        if (tagsLower.includes(query)) score += 20;

        return { ...item, _score: score };
      }).sort((a, b) => b._score - a._score);

      // 显示结果统计
      resultsCount.textContent = `找到 ${matched.length} 个结果`;

      if (matched.length === 0) {
        resultsContainer.innerHTML = `
          <div class="workspace-card text-center p-8 text-surface-400 text-sm">
            没有找到匹配 “${searchInput.value}” 的内容
          </div>
        `;
        return;
      }

      resultsContainer.innerHTML = matched.map(item => {
        const typeLabels = {
          note: { label: '笔记 (NO)', class: 'bg-blue-50 text-blue-700 border-blue-200' },
          project: { label: '项目 (PR)', class: 'bg-green-50 text-green-700 border-green-200' },
          deck: { label: '文稿 (DE)', class: 'bg-purple-50 text-purple-700 border-purple-200' },
          resume: { label: '简历 (RE)', class: 'bg-amber-50 text-amber-700 border-amber-200' }
        };

        const tInfo = typeLabels[item.type] || { label: '其他', class: 'bg-surface-50 text-surface-500 border-surface-200' };
        const tagsHtml = item.tags.map(tag => `<span class="tech-tag">${tag}</span>`).join('');

        return `
          <div class="workspace-card block p-5 hover:border-surface-300 transition-colors">
            <div class="flex items-start justify-between gap-4">
              <div class="space-y-2">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="font-semibold text-surface-900 text-base">${item.title}</h3>
                  <span class="status-tag ${tInfo.class}">${tInfo.label}</span>
                </div>
                <p class="text-sm text-surface-600 leading-relaxed">${item.summary}</p>
                <div class="flex flex-wrap items-center gap-2 pt-2">
                  ${tagsHtml}
                  <span class="text-[10px] text-surface-400 font-mono select-all">路径: ${item.sourcePath}</span>
                </div>
              </div>
              <a href="${item.url}" class="text-xs font-semibold text-accent hover:underline flex items-center gap-0.5 shrink-0 bg-blue-50 px-3 py-1.5 rounded-md hover:bg-blue-100 transition-colors">
                直达 <span>↗</span>
              </a>
            </div>
          </div>
        `;
      }).join('');
    }

    window.addEventListener('DOMContentLoaded', init);
  </script>
</BaseLayout>
