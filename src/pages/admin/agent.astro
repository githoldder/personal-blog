---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Local Agent Workflow Lab">
  <main class="mx-auto max-w-5xl px-6 py-10">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-blue-700">Suggestion Only</p>
    <h1 class="mt-2 text-3xl font-bold text-slate-950">Local Agent Workflow Lab</h1>
    <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-600">
      这里是 LLM Agent 工作流的本地产品入口。当前实现只展示可审阅的工作流，不调用远程模型、不改写源文件、不改变发布状态。
    </p>

    <section class="mt-8 grid gap-4 md:grid-cols-2">
      {['Summarize', 'Classify', 'Suggest Links', 'Privacy Risk'].map((item) => (
        <article class="rounded border border-slate-200 bg-white p-5">
          <h2 class="text-sm font-bold text-slate-900">{item}</h2>
          <p class="mt-2 text-xs leading-5 text-slate-600">输出必须进入人工 review，不能自动发布或写回 Obsidian。</p>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
