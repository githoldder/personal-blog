---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SemanticGraph3D from '../../components/SemanticGraph3D.jsx';
import SemanticAnalyticsPanel from '../../components/SemanticAnalyticsPanel.jsx';
import GestureGraphControls from '../../components/GestureGraphControls.jsx';
---

<BaseLayout title="3D Knowledge Graph Lab">
  <main class="min-h-screen bg-slate-950 text-white">
    <section class="mx-auto grid max-w-7xl gap-6 px-6 py-8 lg:grid-cols-[1fr_320px]">
      <SemanticGraph3D client:load />
      <aside class="space-y-4">
        <SemanticAnalyticsPanel client:load />
        <GestureGraphControls client:load />
      </aside>
    </section>
  </main>
</BaseLayout>
