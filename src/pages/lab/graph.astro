---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="语义图谱 — Personal Knowledge Asset OS">
  <main class="max-w-4xl mx-auto px-6 py-12">
    <header class="mb-8">
      <a href="/" class="text-sm text-surface-500 hover:text-accent transition-colors">← 返回工作台</a>
      <h1 class="text-2xl font-bold mt-4">语义图谱</h1>
      <p class="text-surface-500 mt-1">
        知识关联可视化（实验室功能）
      </p>
    </header>

    <section class="workspace-card">
      <div class="text-center py-12">
        <div class="text-surface-400 mb-4">
          <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold mb-2">实验室功能</h2>
        <p class="text-surface-500 text-sm mb-4">
          语义图谱可视化将在 Phase 3 实现阶段启用。
        </p>
        <div class="text-sm text-surface-400 space-y-1">
          <p>数据源: <code>public/assets/semantic_graph.json</code></p>
          <p>构建命令: <code>npm run build:semantic</code></p>
          <p>状态: 占位数据已就绪，3D 渲染待实现</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
