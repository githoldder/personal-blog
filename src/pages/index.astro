---
import { getCollection } from 'astro:content';
import { readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import MusicPlayer from '../components/MusicPlayer.astro';

let basics = {
  name: 'caolei',
  label: 'software engineering / knowledge systems / local-first tools',
  summary: '把课程、项目、读书笔记和工程实践整理成一个可以继续生长的个人知识系统。',
  email: '1745399028@qq.com',
  phone: '+86 189-5265-3787',
  url: 'https://caolei.dev',
  location: '常州, 江苏'
};

const resumePath = join(process.cwd(), 'public/assets/resume.json');
if (existsSync(resumePath)) {
  try {
    const resume = JSON.parse(readFileSync(resumePath, 'utf-8'));
    if (resume?.basics) {
      basics = {
        ...basics,
        ...resume.basics,
        name: 'caolei',
        label: resume.basics.label?.replace(/\u66f9\u78ca/g, 'caolei') ?? basics.label,
        summary: resume.basics.summary?.replace(/\u66f9\u78ca/g, 'caolei') ?? basics.summary
      };
    }
  } catch (e) {
    // ignore
  }
}

let graphStats = { nodesCount: 0, edgesCount: 0 };
const graphPath = join(process.cwd(), 'public/assets/semantic_graph.json');
if (existsSync(graphPath)) {
  try {
    const graph = JSON.parse(readFileSync(graphPath, 'utf-8'));
    graphStats.nodesCount = graph?.nodes?.length || 0;
    graphStats.edgesCount = graph?.edges?.length || 0;
  } catch (e) {
    // ignore
  }
}

let books = [];
const libraryPath = join(process.cwd(), 'public/assets/library.json');
if (existsSync(libraryPath)) {
  try {
    const libraryData = JSON.parse(readFileSync(libraryPath, 'utf-8'));
    books = libraryData.books || [];
  } catch (e) {
    // ignore
  }
}

const allNotes = await getCollection('notes');
const publishedNotes = allNotes.filter((entry) => entry.data.status === 'published' && !entry.data.tags.includes('book'));
const notes = publishedNotes
  .map((entry) => ({
    slug: entry.data.slug ?? entry.id,
    title: entry.data.title,
    date: entry.data.date,
    tags: entry.data.tags
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 5);

const classicNotes = publishedNotes
  .map((entry) => ({
    slug: entry.data.slug ?? entry.id,
    title: entry.data.title,
    date: entry.data.date,
    tags: entry.data.tags
  }))
  .filter((note) => !note.slug.startsWith('obsidian-'))
  .sort((a, b) => {
    const score = (note: (typeof classicNotes)[number]) => (
      (note.slug.includes('personal-knowledge-asset-os') ? 100 : 0) +
      (note.slug.startsWith('canvas-') ? 20 : 0) +
      (note.slug.startsWith('excalidraw-') ? 15 : 0) +
      note.tags.length
    );
    return score(b) - score(a) || b.date.getTime() - a.date.getTime();
  })
  .slice(0, 4);

const pinnedProjectSlugs = ['lingobridge', 'file-processor-assistant', 'personal-blog', 'springboot-lgg'];
const allProjects = (await getCollection('projects'))
  .filter((entry) => entry.data.status !== 'archived')
  .map((entry) => ({
    slug: entry.data.slug ?? entry.id,
    title: entry.data.title.replace(/\u66f9\u78ca/g, 'caolei'),
    description: entry.data.description.replace(/\u66f9\u78ca/g, 'caolei'),
    tech: entry.data.tech,
    date: entry.data.date
  }));

const featuredProjects = pinnedProjectSlugs
  .map((slug) => allProjects.find((project) => project.slug === slug))
  .filter(Boolean);

const featureBooks = books
  .slice()
  .sort((a, b) => (b.annotationCount ?? 0) - (a.annotationCount ?? 0))
  .slice(0, 8);

const formatDate = (date: Date) => date.toISOString().slice(0, 10);
const coverPalettes = [
  'cover--sage',
  'cover--mist',
  'cover--rose',
  'cover--gold',
  'cover--paper',
  'cover--blue',
  'cover--moss',
  'cover--shell'
];

const projectLogos = {
  lingobridge: 'LB',
  'file-processor-assistant': 'FP',
  'personal-blog': 'OS',
  'springboot-lgg': 'LG'
};

const heroNodes = [
  { label: 'Resume', href: '/resume', x: 18, y: 52, size: 'large' },
  { label: 'Projects', href: '/projects', x: 40, y: 28, size: 'medium' },
  { label: 'Notes', href: '/notes', x: 64, y: 42, size: 'large' },
  { label: 'Graph', href: '/lab/graph', x: 78, y: 66, size: 'medium' },
  { label: 'Library', href: '/library', x: 48, y: 74, size: 'medium' },
  { label: 'Music', href: '/music', x: 25, y: 78, size: 'small' }
];

const patterns = [
  {
    title: '学习路径',
    description: '把课程、论文、项目和复盘整理成可以回溯的路线，而不是一次性的任务清单。',
    meta: `${publishedNotes.length} notes`,
    href: '/notes'
  },
  {
    title: '图谱化理解',
    description: '用语义节点和边显示知识之间的暗线，帮助我发现重复、缺口和迁移关系。',
    meta: `${graphStats.nodesCount} nodes / ${graphStats.edgesCount} edges`,
    href: '/lab/graph'
  },
  {
    title: '工程化作品',
    description: '把工具、模板、自动化脚本和项目文档沉淀成可交付资产。',
    meta: 'projects',
    href: '/projects'
  },
  {
    title: '阅读批注',
    description: '书籍不是收藏品，而是被拆开、标注、连接并重新使用的思想材料。',
    meta: `${books.length} books`,
    href: '/library'
  }
];
---

<BaseLayout title="caolei" theme="systems">
  <header class="page-header">
    <div class="page-header__copy">
      <p class="small-title">Knowledge garden / personal library / engineering notes</p>
      <h1 class="main-title">
        caolei builds a quiet library for hard things made clear.
      </h1>
      <p class="main-subtitle">
        {basics.summary}
      </p>
    </div>
    <aside class="hero-graph" aria-label="知识图谱星链预览">
      <div class="hero-graph__header">
        <span>Semantic Starlink</span>
        <strong>{graphStats.nodesCount} / {graphStats.edgesCount}</strong>
      </div>
      <div class="hero-graph__field">
        <svg viewBox="0 0 100 100" aria-hidden="true">
          <path d="M18 52 C28 36, 42 30, 64 42 S76 55, 78 66" />
          <path d="M18 52 C30 65, 37 75, 48 74 S61 66, 78 66" />
          <path d="M40 28 C45 40, 50 55, 48 74" />
          <path d="M64 42 C56 52, 49 62, 48 74" />
          <path d="M25 78 C35 72, 51 68, 78 66" />
        </svg>
        {heroNodes.map((node, idx) => (
          <a
            href={node.href}
            class={`hero-node hero-node--${node.size}`}
            style={`--x:${node.x}%;--y:${node.y}%;--delay:${idx * 0.35}s`}
          >
            <span>{node.label}</span>
          </a>
        ))}
        <span class="hero-orbit hero-orbit--a"></span>
        <span class="hero-orbit hero-orbit--b"></span>
      </div>
      <p>Clickable map preview for projects, notes, library, and graph exploration.</p>
    </aside>
  </header>

  <section class="essence-section" aria-label="核心入口">
    <a href="/resume" class="resume-feature">
      <span class="resume-feature__kicker">Resume</span>
      <strong>能力证明</strong>
      <small>{basics.email}</small>
    </a>

    <div class="project-feature-grid">
      {featuredProjects.map((project) => (
        <a href={`/projects/${project.slug}/`} class="project-feature-card">
          <span class="project-logo-mark">{projectLogos[project.slug] || project.title.slice(0, 2)}</span>
          <strong>{project.title}</strong>
          <small>{project.tech.slice(0, 3).join(' / ')}</small>
        </a>
      ))}
    </div>

    <div class="classic-notes">
      <div class="classic-notes__head">
        <h2>Classic Notes <span>→</span></h2>
        <a href="/notes">全部知识笔记</a>
      </div>
      <div class="classic-notes__list">
        {classicNotes.map((note) => (
          <a href={`/notes/${note.slug}/`}>
            <strong>{note.title}</strong>
            <small>{note.tags.slice(0, 2).join(' · ') || formatDate(note.date)}</small>
          </a>
        ))}
      </div>
    </div>

    <MusicPlayer compact />
  </section>

  <section class="garden-section" aria-label="知识呈现形式">
    <div class="essays-section">
      <a href="/notes" class="header-link">
        <h2 class="section-header">Notes <span aria-hidden="true">→</span></h2>
      </a>
      <p class="subheader">Fresh fragments from study, software engineering, and systems thinking.</p>
      <div class="notes-list">
        {notes.map((note) => (
          <a href={`/notes/${note.slug}/`} class="index-note-card">
            <span class="index-note-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M12 2.8 L14.4 9.6 L21.2 12 L14.4 14.4 L12 21.2 L9.6 14.4 L2.8 12 L9.6 9.6 Z"></path>
                <circle cx="12" cy="12" r="4.7"></circle>
              </svg>
            </span>
            <span>
              <strong>{note.title}</strong>
              <small>{note.tags.slice(0, 2).join(' · ') || formatDate(note.date)} · {formatDate(note.date)}</small>
            </span>
          </a>
        ))}
      </div>
    </div>

    <div class="patterns-section">
      <a href="/projects" class="header-link">
        <h2 class="section-header">Patterns <span aria-hidden="true">→</span></h2>
      </a>
      <p class="subheader">Design patterns gathered from my own observations, coursework, and build logs.</p>
      <div class="patterns-grid">
        {patterns.map((pattern) => (
          <a href={pattern.href} class="pattern-card">
            <span class="pattern-card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path class="left-leaf" d="M12 3 C7.5 5.2 5.2 7.5 3 12 C5.2 16.5 7.5 18.8 12 21"></path>
                <path class="right-leaf" d="M12 3 C16.5 5.2 18.8 7.5 21 12 C18.8 16.5 16.5 18.8 12 21"></path>
                <circle cx="12" cy="12" r="3.2"></circle>
              </svg>
            </span>
            <span>
              <strong>{pattern.title}</strong>
              <em>{pattern.description}</em>
              <small>{pattern.meta}</small>
            </span>
          </a>
        ))}
      </div>
    </div>

    <div class="library-section">
      <a href="/library" class="header-link">
        <h2 class="section-header">Library <span aria-hidden="true">→</span></h2>
      </a>
      <p class="subheader">Books, annotated PDFs, and ideas that keep returning as useful tools.</p>
      <div class="books-grid">
        {featureBooks.map((book, idx) => (
          <a href={`/notes/${book.slug}/`} class="book-card">
            <span class={`book-cover ${coverPalettes[idx % coverPalettes.length]}`}>
              {book.coverUrl ? (
                <img src={book.coverUrl} alt={`《${book.title}》封面`} loading="lazy" />
              ) : (
                <>
                  <span class="book-cover__meta">{book.annotationCount ?? 0} notes</span>
                  <strong>{book.title}</strong>
                  <small>{book.author && book.author !== '未知作者' ? book.author : 'caolei annotations'}</small>
                </>
              )}
            </span>
            <span class="book-title">{book.title}</span>
            <span class="book-author">{book.author && book.author !== '未知作者' ? book.author : 'reading note'}</span>
          </a>
        ))}
      </div>
    </div>

    <aside class="system-section" aria-label="System details">
      <h2 class="section-header">System <span aria-hidden="true">→</span></h2>
      <p class="subheader">淡色表面下保留工程细节：索引、图谱、发布流水线和本地资产。</p>
      <dl class="system-list">
        <div>
          <dt>Graph nodes</dt>
          <dd>{graphStats.nodesCount}</dd>
        </div>
        <div>
          <dt>Graph edges</dt>
          <dd>{graphStats.edgesCount}</dd>
        </div>
        <div>
          <dt>Published notes</dt>
          <dd>{publishedNotes.length}</dd>
        </div>
        <div>
          <dt>Library records</dt>
          <dd>{books.length}</dd>
        </div>
      </dl>
      <nav class="quiet-links" aria-label="Secondary links">
        <a href="/search">Search</a>
        <a href="/resume">Resume</a>
        <a href={`mailto:${basics.email}`}>Email</a>
        <a href="/admin">Admin</a>
      </nav>
    </aside>
  </section>
</BaseLayout>

<style>
  .page-header {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.85fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    margin-top: clamp(1.4rem, 3.8vw, 3rem);
    margin-bottom: clamp(1.4rem, 3vw, 2.4rem);
  }

  .small-title {
    font-family: Avenir, 'Avenir Next', Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(1.05rem, 1.6vw, 1.35rem);
    color: var(--color-gray-800);
    font-weight: 300;
    line-height: 1.75;
    margin: 0 0 0.8rem;
  }

  .main-title {
    max-width: 920px;
    font-size: clamp(3rem, 6.1vw, 6.05rem);
    line-height: 0.94;
    font-weight: 400;
    color: var(--color-gray-800);
    margin: 0;
  }

  .main-subtitle {
    max-width: 820px;
    margin: 1.05rem 0 0;
    font-family: Avenir, 'Avenir Next', Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(1rem, 1.35vw, 1.22rem);
    line-height: 1.68;
    color: var(--color-gray-600);
    font-weight: 300;
  }

  .hero-graph {
    position: relative;
    min-height: clamp(320px, 35vw, 480px);
    border-left: 1px solid var(--color-tinted-cream);
    padding-left: clamp(1.2rem, 2.5vw, 2.2rem);
    color: var(--color-gray-600);
  }

  .hero-graph__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-gray-500);
  }

  .hero-graph__header strong {
    color: var(--color-gray-800);
    font-weight: 700;
  }

  .hero-graph__field {
    position: relative;
    height: clamp(270px, 30vw, 410px);
    margin-top: 0.8rem;
    border-radius: 50%;
    background:
      radial-gradient(circle at 50% 50%, rgb(255 255 255 / 0.72), transparent 58%),
      radial-gradient(circle at 64% 42%, color-mix(in srgb, var(--color-sea-blue) 16%, transparent), transparent 22%),
      radial-gradient(circle at 30% 74%, color-mix(in srgb, var(--color-crimson) 10%, transparent), transparent 24%);
    overflow: hidden;
  }

  .hero-graph__field svg {
    position: absolute;
    inset: 7%;
    width: 86%;
    height: 86%;
    overflow: visible;
  }

  .hero-graph__field path {
    fill: none;
    stroke: color-mix(in srgb, var(--color-sea-blue) 42%, var(--color-tinted-cream));
    stroke-width: 0.42;
    stroke-dasharray: 2 4;
    stroke-linecap: round;
    animation: starlinkTrace 9s linear infinite;
  }

  .hero-node {
    position: absolute;
    left: var(--x);
    top: var(--y);
    transform: translate(-50%, -50%);
    width: 0.72rem;
    aspect-ratio: 1;
    border-radius: 999px;
    background: var(--color-paper);
    border: 1px solid var(--color-sea-blue);
    box-shadow:
      0 0 0 0 color-mix(in srgb, var(--color-sea-blue) 22%, transparent),
      0 10px 24px rgb(39 78 88 / 0.12);
    animation: heroNodePulse 4.8s ease-in-out infinite;
    animation-delay: var(--delay);
    text-decoration: none;
  }

  .hero-node--medium {
    width: 0.92rem;
    border-color: color-mix(in srgb, var(--color-crimson) 44%, var(--color-sea-blue));
  }

  .hero-node--large {
    width: 1.16rem;
    background: color-mix(in srgb, var(--color-paper) 86%, white);
    border-color: var(--color-crimson);
  }

  .hero-node span {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.45rem);
    transform: translateX(-50%);
    white-space: nowrap;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.62rem;
    color: var(--color-gray-600);
    opacity: 0.82;
  }

  .hero-node:hover {
    background: var(--color-crimson);
    border-color: var(--color-crimson);
  }

  .hero-node:hover span {
    color: var(--color-crimson);
  }

  .hero-orbit {
    position: absolute;
    inset: 13%;
    border: 1px solid color-mix(in srgb, var(--color-tinted-cream) 70%, transparent);
    border-radius: 50%;
    animation: heroOrbitSpin 28s linear infinite;
  }

  .hero-orbit--b {
    inset: 25% 19%;
    transform: rotate(28deg);
    animation-duration: 21s;
    animation-direction: reverse;
  }

  .hero-graph p {
    margin: 0.65rem 0 0;
    font-size: 0.86rem;
    line-height: 1.55;
    color: var(--color-gray-500);
  }

  .garden-section {
    display: grid;
    grid-template-columns: minmax(280px, 0.95fr) minmax(420px, 1.55fr);
    grid-template-areas:
      "notes library"
      "patterns library"
      "system library";
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
    margin: 0 0 clamp(3rem, 7vw, 6rem);
  }

  .essence-section {
    display: grid;
    grid-template-columns: minmax(140px, 0.45fr) minmax(360px, 1.25fr) minmax(300px, 0.9fr);
    grid-template-areas:
      "resume projects notes"
      "music projects notes";
    gap: clamp(1rem, 2vw, 1.75rem);
    align-items: stretch;
    margin: 0 0 clamp(2.4rem, 5vw, 4.2rem);
    padding: clamp(0.85rem, 1.5vw, 1rem) 0;
    border-top: 1px solid var(--color-tinted-cream);
    border-bottom: 1px solid var(--color-tinted-cream);
  }

  .resume-feature {
    grid-area: resume;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 7.2rem;
    color: var(--color-gray-800);
    text-decoration: none;
    border-bottom: 1px solid var(--color-tinted-cream);
    padding-bottom: 0.85rem;
  }

  .resume-feature__kicker,
  .project-feature-card small,
  .classic-notes small {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.68rem;
    color: var(--color-gray-500);
    text-transform: uppercase;
  }

  .resume-feature strong {
    display: block;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.65rem, 2.5vw, 2.6rem);
    font-weight: 400;
    line-height: 0.98;
    color: var(--color-gray-800);
  }

  .resume-feature small {
    color: var(--color-gray-600);
    font-size: 0.95rem;
  }

  .project-feature-grid {
    grid-area: projects;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .project-feature-card {
    min-height: 10.4rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--color-gray-800);
    text-decoration: none;
    border: 1px solid var(--color-tinted-cream);
    border-radius: 6px;
    background: rgb(255 255 255 / 0.34);
    padding: 0.9rem;
    transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
  }

  .project-feature-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-sea-blue) 54%, var(--color-tinted-cream));
    background: rgb(255 255 255 / 0.58);
  }

  .project-logo-mark {
    width: 3.2rem;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-sea-blue) 48%, var(--color-tinted-cream));
    color: var(--color-crimson);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.25rem;
    font-style: italic;
  }

  .project-feature-card strong {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.1rem, 1.5vw, 1.45rem);
    font-weight: 400;
    line-height: 1.12;
  }

  .classic-notes {
    grid-area: notes;
  }

  .classic-notes__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .classic-notes__head h2 {
    margin: 0;
    font-family: Avenir, 'Avenir Next', Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-gray-800);
  }

  .classic-notes__head a {
    font-size: 0.82rem;
  }

  .classic-notes__list {
    display: grid;
    gap: 0.2rem;
  }

  .classic-notes__list a {
    display: grid;
    gap: 0.25rem;
    padding: 0.52rem 0;
    border-bottom: 1px solid var(--color-tinted-cream);
    color: var(--color-gray-800);
    text-decoration: none;
  }

  .classic-notes__list strong {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.2;
  }

  .essence-section .music-player {
    grid-area: music;
    align-self: end;
  }

  @keyframes starlinkTrace {
    to { stroke-dashoffset: -60; }
  }

  @keyframes heroNodePulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-sea-blue) 20%, transparent), 0 10px 24px rgb(39 78 88 / 0.12); }
    50% { box-shadow: 0 0 0 10px transparent, 0 14px 30px rgb(39 78 88 / 0.16); }
  }

  @keyframes heroOrbitSpin {
    to { transform: rotate(360deg); }
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 0.55rem;
    font-family: Avenir, 'Avenir Next', Inter, ui-sans-serif, system-ui, sans-serif;
