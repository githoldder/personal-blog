---
import { getCollection } from 'astro:content';
import { readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import GrowthBadge from '../components/GrowthBadge.astro';
import CoordinateAxis from '../components/CoordinateAxis.astro';

// 1. 读取基础简历元数据
let basics = {
  name: 'githoldder',
  label: '软件工程学子 / 在校创业者 / 知识系统架构师',
  summary: '常州工学院软件工程专业本科生。主修软件工程，构建高效实用的工程工具。'
};

const resumePath = join(process.cwd(), 'public/assets/resume.json');
if (existsSync(resumePath)) {
  try {
    const resume = JSON.parse(readFileSync(resumePath, 'utf-8'));
    if (resume?.basics) {
      basics = resume.basics;
    }
  } catch (e) {
    // ignore
  }
}

const publicBasics = {
  ...basics,
  name: 'githoldder',
  label: basics.label?.replace(/\u66f9\u78ca/g, 'caolei') ?? 'caolei / knowledge systems / software engineering',
  summary: basics.summary?.replace(/\u66f9\u78ca/g, 'caolei') ?? ''
};

// 2. 读取语义图谱数据得到统计
let graphStats = { nodesCount: 0, edgesCount: 0 };
const graphPath = join(process.cwd(), 'public/assets/semantic_graph.json');
if (existsSync(graphPath)) {
  try {
    const graph = JSON.parse(readFileSync(graphPath, 'utf-8'));
    graphStats.nodesCount = graph?.nodes?.length || 0;
    graphStats.edgesCount = graph?.edges?.length || 0;
  } catch (e) {
    // ignore
  }
}

// 3. 读取 Library 书籍用于阅读地层 (Reading Strata)
let books = [];
const libraryPath = join(process.cwd(), 'public/assets/library.json');
if (existsSync(libraryPath)) {
  try {
    const libraryData = JSON.parse(readFileSync(libraryPath, 'utf-8'));
    books = libraryData.books || [];
  } catch (e) {
    // ignore
  }
}

// 4. 读取 Content Collections 笔记并筛选
const allNotes = await getCollection('notes');
const publishedNotes = allNotes.filter((entry) => entry.data.status === 'published' && !entry.data.tags.includes('book'));
const notes = publishedNotes
  .map((entry) => {
    let stage = 'seedling';
    if (entry.data.tags.includes('evergreen') || entry.id.length < 32) {
      stage = 'evergreen';
    } else if (entry.data.tags.includes('budding') || entry.data.title.length > 8) {
      stage = 'budding';
    }
    return {
      slug: entry.data.slug ?? entry.id,
      title: entry.data.title,
      date: entry.data.date,
      tags: entry.data.tags,
      stage
    };
  })
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 4);

const tagCounts = new Map<string, number>();
for (const entry of publishedNotes) {
  for (const tag of entry.data.tags) {
    if (!tag || tag === 'book') continue;
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const topTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

const maxTagCount = Math.max(1, ...topTags.map(([, count]) => count));
const formatDate = (date: Date) => date.toISOString().slice(0, 10);
const buildTime = new Date().toISOString();
basics.name = 'githoldder';
basics.label = basics.label?.replace(/\u66f9\u78ca/g, 'caolei') || 'knowledge system builder';

// 定义书脊颜色循环
const spineColors = [
  'bg-[#e2ecc8] text-[#3d5a23] border-[#ccd9a3] hover:bg-[#d9e5b8]', // moss-green
  'bg-[#fde2e4] text-[#8a333a] border-[#fbc4c6] hover:bg-[#fcd2d5]', // rose-pink
  'bg-[#fef2cd] text-[#785b00] border-[#fce498] hover:bg-[#fdeba7]', // gold-yellow
  'bg-[#e3ecf5] text-[#2c5270] border-[#c0d5e8] hover:bg-[#d2e4f2]'  // blue-ice
];

const shelfBooks = books
  .slice()
  .sort((a, b) => (b.annotationCount ?? 0) - (a.annotationCount ?? 0))
  .slice(0, 6);

const featureBook = shelfBooks[0] ?? books[0];
const hotlinks = [
  {
    title: 'Knowledge Asset OS',
    href: '/notes/2026-06-26-personal-knowledge-asset-os/',
    meta: `${graphStats.nodesCount} nodes / ${graphStats.edgesCount} edges`
  },
  { title: '全部笔记', href: '/notes', meta: `${publishedNotes.length} published` },
  { title: '项目仪器台', href: '/projects', meta: 'shipping tools' },
  { title: '语义图谱', href: '/lab/graph', meta: 'explore graph' },
  { title: '图书馆', href: '/library', meta: `${books.length} books` }
];
---

<BaseLayout title="OS Instance Workbench" theme="systems">
  <header class="home-hero select-none">
    <div class="home-hero__copy">
      <div class="inline-flex items-center gap-1.5 px-2 py-0.5 text-[9px] font-mono font-bold tracking-widest text-rose-800 bg-rose-50 border border-rose-200/50 rounded uppercase mb-4">
        WORKBENCH ROOT
      </div>
      <h1 class="text-3xl md:text-5xl font-serif font-bold text-slate-900 leading-tight">
        {publicBasics.name}
        <span class="text-base md:text-lg font-mono text-slate-500 block sm:inline sm:pl-3 font-normal">{publicBasics.label}</span>
      </h1>
      <p class="mt-4 font-serif text-slate-700 leading-relaxed text-sm md:text-base max-w-2xl">
        {publicBasics.summary}
      </p>
      <nav class="home-hotlinks" aria-label="Workbench hotlinks">
        {hotlinks.map((link) => (
          <a href={link.href} class="home-hotlink">
            <span>{link.title}</span>
            <small>{link.meta}</small>
          </a>
        ))}
      </nav>
    </div>

    {featureBook && (
      <aside class="book-window" aria-label="Library preview">
        <div class="book-window__shelf">
          {shelfBooks.slice(0, 5).map((book, idx) => (
            <a
              href={`/notes/${book.slug}/`}
              class={`book-window__spine ${spineColors[idx % spineColors.length]}`}
              style={`--book-height: ${72 + Math.min(44, (book.annotationCount ?? 0) * 2)}px`}
              aria-label={`打开《${book.title}》的 annotator 笔记`}
            >
              <span>{book.title}</span>
            </a>
          ))}
        </div>
        <div class="book-window__detail">
          <span class="font-mono text-[9px] font-bold uppercase tracking-widest text-slate-400">book window</span>
          <h2 class="mt-2 text-xl md:text-2xl font-serif font-bold text-slate-900 line-clamp-2">《{featureBook.title}》</h2>
          <p class="mt-2 text-xs md:text-sm leading-relaxed text-slate-600 line-clamp-3">{featureBook.summary}</p>
          <div class="mt-4 flex items-center justify-between gap-3">
            <span class="font-mono text-[10px] text-slate-500">{featureBook.annotationCount ?? 0} annotations</span>
            <a href={`/notes/${featureBook.slug}/`} class="font-mono text-[10px] font-bold text-rose-700 hover:underline">
              看 annotator 笔记
            </a>
          </div>
        </div>
      </aside>
    )}
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start border-t border-slate-200/60 pt-8 md:pt-10">
    
    <!-- Left Column: The Garden (8/12 Columns in Large View) -->
    <div class="lg:col-span-8 space-y-12">
      
      <!-- Notes Garden Stream -->
      <section class="space-y-6">
        <div class="flex items-center justify-between border-b border-slate-100 pb-3">
          <h2 class="text-xl md:text-2xl font-serif font-bold text-slate-900">
            知识生长轨迹
          </h2>
          <a href="/notes" class="text-xs font-mono text-rose-700 hover:underline font-bold">调阅所有笔记 ↗</a>
        </div>

        <div class="space-y-1">
          {notes.map((note) => (
            <article class="garden-item">
              <div class="flex items-start justify-between gap-4">
                <div class="space-y-1.5">
                  <div class="flex items-center gap-2">
                    <GrowthBadge stage={note.stage} />
                  </div>
                  <h3 class="font-serif font-bold text-base md:text-lg text-slate-900">
                    <a href={`/notes/${note.slug}/`} class="hover:text-rose-700 transition-colors leading-snug">
                      {note.title}
                    </a>
                  </h3>
                  <div class="flex items-center gap-3 text-xs text-slate-400 font-mono">
                    <time datetime={formatDate(note.date)}>{formatDate(note.date)}</time>
                    <div class="flex gap-1">
                      {note.tags.slice(0, 2).map((t) => (
                        <span class="tech-tag">#{t}</span>
                      ))}
                    </div>
                  </div>
                </div>
                <code class="text-[9px] font-mono text-slate-400/80 uppercase">/{note.slug.slice(0, 10)}</code>
              </div>
            </article>
          ))}
        </div>
      </section>

      {books.length > 0 && (
        <section class="space-y-4">
          <CoordinateAxis label="Library Shelf" value={`${books.length} books`} />
          <div class="compact-shelf">
            {shelfBooks.map((book, idx) => {
              const colorClass = spineColors[idx % spineColors.length];
              return (
                <a
                  href={`/notes/${book.slug}/`}
                  class={`compact-book ${colorClass}`}
                  aria-label={`打开《${book.title}》`}
                >
                  <span class="line-clamp-2">《{book.title}》</span>
                  <small>{book.annotationCount ?? 0} notes</small>
                </a>
              );
            })}
          </div>
        </section>
      )}
    </div>

    <div class="lg:col-span-4 space-y-10 lg:pl-4">
      <section class="space-y-4">
        <CoordinateAxis label="Graph Preview" value="live index" />
        
        <div class="relative aspect-square w-full rounded-full border border-dashed border-slate-300/80 overflow-hidden flex items-center justify-center bg-white/40 coordinate-grid group hover:border-rose-400 transition-colors duration-300">
          <svg class="w-3/4 h-3/4 graph-preview-orbit" viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="3.5" fill="var(--color-rose)"></circle>
            
            <line x1="50" y1="50" x2="25" y2="25" stroke="#cbd5e1" stroke-width="0.75" stroke-dasharray="2,2"></line>
            <circle cx="25" cy="25" r="2" fill="var(--color-moss)"></circle>
            
            <line x1="50" y1="50" x2="78" y2="42" stroke="#cbd5e1" stroke-width="0.75"></line>
            <circle cx="78" cy="42" r="3" fill="var(--color-rose)"></circle>
            
            <line x1="50" y1="50" x2="40" y2="78" stroke="#cbd5e1" stroke-width="0.75"></line>
            <circle cx="40" cy="78" r="2.5" fill="var(--color-signal)"></circle>
          </svg>
          <div class="absolute bottom-4 text-center">
            <a href="/lab/graph" class="inline-flex items-center justify-center px-4 py-1.5 border border-slate-900/10 hover:border-slate-900 text-[10px] font-mono font-bold text-slate-800 bg-white/90 backdrop-blur-sm rounded transition-all">
              交互式拓扑图谱 ↗
            </a>
          </div>
        </div>
      </section>

      <section class="space-y-4 pt-4">
        <CoordinateAxis label="System runtime benchmarks" value={`t=${buildTime.slice(0, 10)}`} />
        
        <div class="font-mono text-[10px] text-slate-500 space-y-2.5">
          <div class="flex justify-between border-b border-slate-100 pb-1.5">
            <span>GRAPH NODES COMPUTED</span>
            <span class="font-bold text-slate-800">{graphStats.nodesCount}</span>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-1.5">
            <span>GRAPH EDGES CALCULATED</span>
            <span class="font-bold text-slate-800">{graphStats.edgesCount}</span>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-1.5">
            <span>PUBLISHABLE NOTES</span>
            <span class="font-bold text-slate-800">{publishedNotes.length}</span>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-1.5">
            <span>TOP TAGS</span>
            <span class="font-bold text-slate-800">{topTags.length}/{maxTagCount}</span>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-1.5">
            <span>PIPELINE ENGINE</span>
            <span class="text-slate-800">ASTRO 5.10 / ESBUILD</span>
          </div>
        </div>
      </section>

      <section class="pt-8 border-t border-slate-200/50">
        <a 
          href="/admin" 
          class="inline-flex items-center gap-1 text-[9px] font-mono font-bold text-slate-400 hover:text-rose-700 transition-colors uppercase tracking-widest"
        >
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-slate-300 group-hover:bg-rose-500"></span>
          Offline Admin console gate ➔
        </a>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  @keyframes spin-slow {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .home-hero {
    min-height: min(560px, calc(100vh - 8rem));
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
    padding: clamp(1rem, 3vw, 2.5rem) 0 clamp(2rem, 6vw, 4rem);
  }

  .home-hero__copy {
    max-width: 46rem;
  }

  .home-hotlinks {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .home-hotlink {
    min-height: 4.75rem;
    padding: 0.75rem;
    border: 1px solid rgb(226 232 240 / 0.85);
    border-radius: 6px;
    background: rgb(255 255 255 / 0.42);
    color: rgb(15 23 42);
    text-decoration: none;
  }

  .home-hotlink span,
  .home-hotlink small {
    display: block;
  }

  .home-hotlink span {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.76rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .home-hotlink small {
    margin-top: 0.55rem;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.58rem;
    line-height: 1.2;
    color: rgb(100 116 139);
  }

  .home-hotlink:hover,
  .home-hotlink:focus-visible {
    border-color: color-mix(in srgb, var(--theme-a, #4f8f68) 50%, rgb(226 232 240));
    background: color-mix(in srgb, var(--theme-a, #4f8f68) 8%, white);
    transform: translateY(-2px);
  }

  .book-window {
    border: 1px solid rgb(226 232 240 / 0.9);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.68), rgb(255 255 255 / 0.32)),
      radial-gradient(circle at 88% 18%, color-mix(in srgb, var(--theme-b, #d9b86c) 16%, transparent), transparent 14rem);
    padding: 1rem;
    box-shadow: 0 16px 40px rgb(15 23 42 / 0.07);
  }

  .book-window__shelf {
    min-height: 8rem;
    display: flex;
    align-items: end;
    gap: 0.5rem;
    padding: 0.75rem 0.25rem 0.5rem;
    border-bottom: 2px solid rgb(148 163 184 / 0.28);
  }

  .book-window__spine {
    width: 2.05rem;
    height: var(--book-height, 84px);
    min-height: 4.5rem;
    max-height: 7.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.25rem;
    border-radius: 4px 4px 2px 2px;
    writing-mode: vertical-rl;
    text-orient: mixed;
    text-decoration: none;
    overflow: hidden;
  }

  .book-window__spine span {
    max-height: 6.6rem;
    overflow: hidden;
    font-size: 0.62rem;
    line-height: 1.2;
    font-weight: 800;
  }

  .book-window__detail {
    padding: 1rem 0.25rem 0.25rem;
  }

  .compact-shelf {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .compact-book {
    min-height: 7rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0.85rem;
    border-radius: 6px;
    text-decoration: none;
  }

  .compact-book span {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.95rem;
    line-height: 1.25;
    font-weight: 800;
  }

  .compact-book small {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.62rem;
    opacity: 0.72;
  }

  .graph-preview-orbit {
    animation: spin-slow 60s linear infinite;
  }

  /* 书架 Spines Shelf 动画细节与排版 */
  .book-spine {
    writing-mode: vertical-rl;
    text-orient: mixed;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    height: 280px;
    width: 44px;
    padding: 1.5rem 0.5rem;
    position: relative;
    outline: none;
  }
  .book-spine:focus-visible {
    outline: 2px solid var(--color-rose);
    outline-offset: 3px;
  }

  @media (min-width: 1024px) {
    .book-spine:hover, .book-spine:focus {
      width: 240px;
      writing-mode: horizontal-tb;
      padding: 1.5rem 1.25rem;
    }
    .book-spine .spine-detail {
      opacity: 0;
      transition: opacity 0.2s ease;
      display: none;
    }
    .book-spine:hover .spine-detail, .book-spine:focus .spine-detail {
      opacity: 1;
      display: flex;
    }
    .book-spine:hover .spine-title-vertical, .book-spine:focus .spine-title-vertical {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .home-hero {
      min-height: auto;
      grid-template-columns: 1fr;
      padding-top: 1rem;
    }

    .home-hotlinks {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .book-window {
      max-width: 34rem;
    }
  }

  @media (max-width: 560px) {
    .home-hotlinks,
    .compact-shelf {
      grid-template-columns: 1fr;
    }

    .home-hotlink {
      min-height: 3.4rem;
    }

    .book-window__spine {
      width: 1.85rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .graph-preview-orbit {
      animation: none;
    }
  }
</style>
