---
import { readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ParchmentStack from '../../components/ParchmentStack.astro';
import CoordinateAxis from '../../components/CoordinateAxis.astro';

const ROOT = process.cwd();
const MANIFEST_PATH = join(ROOT, 'public/assets/decks/manifest.json');

let decks = [];
if (existsSync(MANIFEST_PATH)) {
  try {
    const raw = readFileSync(MANIFEST_PATH, 'utf-8');
    const manifest = JSON.parse(raw);
    decks = manifest.decks || [];
  } catch (e) {
    console.error('Failed to parse decks manifest:', e.message);
  }
}

// 动态检测本地物理构建产物是否存在
function checkBuildStatus(deck) {
  const htmlPhysicalPath = join(ROOT, 'public/slides', deck.slug, 'index.html');
  const hasHtml = existsSync(htmlPhysicalPath);

  const pdfPhysicalPath = join(ROOT, 'public/assets', `${deck.slug}.pdf`);
  const hasPdf = existsSync(pdfPhysicalPath);

  return { hasHtml, hasPdf };
}
---

<BaseLayout title="文稿库 — Personal Knowledge Asset OS">
  
  <header class="pb-8 pt-6 select-none max-w-4xl">
    <div class="inline-flex items-center gap-1.5 px-2 py-0.5 text-[9px] font-mono font-bold tracking-widest text-rose-800 bg-rose-50 border border-rose-200/50 rounded uppercase mb-4">
      SLIDE COMPILING PIPELINE
    </div>
    <h1 class="text-3xl md:text-4xl font-serif font-bold text-slate-900 leading-tight">🎴 演示文稿管线</h1>
    <p class="mt-3 font-serif text-slate-600 leading-relaxed text-sm md:text-base max-w-3xl">
      集成自 Slidev 现代化幻灯片构建管线。所有演示幻灯片均以单一 Markdown 格式存储在 <code>content/decks/</code> 中，并支持编译为静态 HTML 和高精度 PDF 离线包。
    </p>
  </header>

  <!-- Asymmetric Split Grid Layout -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start border-t border-slate-200/60 pt-8">
    
    <!-- Left Column: Decks grid of Offset Stacks (8/12 Columns) -->
    <section class="lg:col-span-8 space-y-6">
      <CoordinateAxis label="Active Slide Stacks" value={`${decks.length} item(s)`} />
      
      {decks.length === 0 ? (
        <div class="py-12 text-center text-slate-400 font-serif border border-slate-200/50 rounded-md">
          <p>暂无演示文稿数据，请先在 <code>content/decks/</code> 中创建幻灯片并运行构建。</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {decks.map((deck) => {
            const { hasHtml, hasPdf } = checkBuildStatus(deck);
            return (
              <ParchmentStack 
                slug={deck.slug}
                title={deck.title}
                date={deck.date}
                hasHtml={hasHtml}
                hasPdf={hasPdf}
              />
            );
          })}
        </div>
      )}
    </section>

    <!-- Right Column: Precision configuration specs (4/12 Columns) -->
    <section class="lg:col-span-4 space-y-4">
      <CoordinateAxis label="Slidev Compiler Registry" value="Port=3000" />
      
      <div class="font-mono text-[9px] text-slate-500 space-y-2.5 bg-slate-50/50 border border-slate-200/50 p-4 rounded-md leading-relaxed">
        <div class="flex justify-between border-b border-slate-200/40 pb-1">
          <span>COMPILER CMD</span>
          <span class="text-slate-800 font-bold">npm run build:decks</span>
        </div>
        <div class="flex justify-between border-b border-slate-200/40 pb-1">
          <span>SOURCE DIR</span>
          <span class="text-slate-800 font-bold">content/decks/*.md</span>
        </div>
        <div class="flex justify-between border-b border-slate-200/40 pb-1">
          <span>PREVIEW DIR</span>
          <span class="text-slate-800 font-bold truncate max-w-[150px]" title="public/slides/<slug>/index.html">public/slides/&lt;slug&gt;/</span>
        </div>
        <div class="flex justify-between">
          <span>PDF EXPORTED</span>
          <span class="text-slate-800 font-bold">public/assets/&lt;slug&gt;.pdf</span>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
