---
interface Props {
  title: string;
  href: string;
  desc: string;
  image: string;
}

const { title, href, desc, image } = Astro.props;
---

<a 
  href={href} 
  class="group block pb-8 hover:no-underline select-none"
  aria-label={`阅读论述: ${title}`}
>
  <div class="relative overflow-hidden rounded-md border border-slate-200/50 bg-slate-50/50 aspect-[4/3] w-full flex items-center justify-center transition-all duration-300 hover:border-rose-300/60 shadow-[0_1px_3px_rgba(0,0,0,0.02)]">
    <img 
      src={image} 
      alt={`插图: ${title}`} 
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] group-hover:scale-105"
    />
  </div>
  <div class="mt-4 space-y-2">
    <h3 class="text-lg md:text-xl font-serif font-bold text-slate-900 group-hover:text-rose-700 transition-colors leading-snug">
      {title}
    </h3>
    <p class="text-xs md:text-sm text-slate-600 font-serif leading-relaxed line-clamp-3">
      {desc}
    </p>
  </div>
</a>
