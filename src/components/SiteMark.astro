<a
  href="/"
  class="site-mark"
  aria-label="caolei mark"
  data-site-mark
>
  <svg class="site-mark__glyph" viewBox="0 0 72 42" role="img" aria-hidden="true">
    <path class="site-mark__c" d="M39 9 C32 3, 18 4, 11 13 C4 22, 8 35, 20 38 C28 40, 35 37, 39 32"></path>
    <path class="site-mark__l" d="M40 5 L40 34 L58 34"></path>
    <path class="site-mark__join" d="M28 21 C33 20, 37 20, 42 21"></path>
    <circle class="site-mark__node site-mark__node--a" cx="40" cy="5" r="2.2"></circle>
    <circle class="site-mark__node site-mark__node--b" cx="58" cy="34" r="2.2"></circle>
  </svg>
</a>

<script is:inline>
  const mark = document.querySelector('[data-site-mark]');
  let logoTimer;

  const animateLogo = () => {
    if (!mark) return;
    window.clearTimeout(logoTimer);
    mark.classList.add('site-mark--animate');
    logoTimer = window.setTimeout(() => mark.classList.remove('site-mark--animate'), 640);
  };

  mark?.addEventListener('mouseenter', animateLogo);
  mark?.addEventListener('pointerenter', animateLogo);
  mark?.addEventListener('focus', animateLogo);
  window.addEventListener('site-mark:route-complete', animateLogo);
</script>
