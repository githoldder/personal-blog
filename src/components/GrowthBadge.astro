---
interface Props {
  stage: 'seedling' | 'budding' | 'evergreen' | string;
}

const { stage } = Astro.props;

// 标准化
const norm = String(stage).toLowerCase().trim();

let text = '种子';
let classes = 'text-green-700 bg-green-50/50 border-green-200/60';
let ariaLabel = '知识生长期：🌱 种子阶段 — 零散的灵感火花';

if (norm.includes('evergreen') || norm.includes('常青')) {
  text = '常青';
  classes = 'text-emerald-800 bg-emerald-50/50 border-emerald-300/60 font-bold';
  ariaLabel = '知识生长期：🌳 常青阶段 — 体系化、高频互联的知识资产';
} else if (norm.includes('budding') || norm.includes('萌芽')) {
  text = '萌芽';
  classes = 'text-teal-700 bg-teal-50/50 border-teal-200/60';
  ariaLabel = '知识生长期：🌿 萌芽阶段 — 经过重构，已建立一定双向链接';
}
---

<span 
  class={`inline-flex items-center gap-1 px-2 py-0.5 text-[9px] font-mono font-bold tracking-wider rounded uppercase border transition-all ${classes}`}
  role="img"
  aria-label={ariaLabel}
  title={ariaLabel}
>
  {norm.includes('evergreen') || norm.includes('常青') ? (
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 text-emerald-600 shrink-0">
      <path d="M12 2a1 1 0 0 1 .8.4l1.6 2.2a3 3 0 0 0 1.6 1.1l2.6.4a1 1 0 0 1 .6 1.7l-2 1.8a3 3 0 0 0-.9 2.1v2.7a1 1 0 0 1-1.5.9l-2.3-1.4a3 3 0 0 0-3 0l-2.3 1.4a1 1 0 0 1-1.5-.9v-2.7a3 3 0 0 0-.9-2.1l-2-1.8a1 1 0 0 1 .6-1.7l2.6-.4a3 3 0 0 0 1.6-1.1L11.2 2.4A1 1 0 0 1 12 2z"/>
    </svg>
  ) : norm.includes('budding') || norm.includes('萌芽') ? (
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 text-teal-600 shrink-0">
      <path d="M12 3a9 9 0 0 0-9 9 9 9 0 0 0 9 9 9 9 0 0 0 9-9h-9V3z"/>
    </svg>
  ) : (
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 text-green-600 shrink-0">
      <path d="M12 2.25a.75.75 0 0 1 .75.75v3.25a6 6 0 0 1 6 6v3.25a.75.75 0 0 1-1.5 0v-3.25a4.5 4.5 0 0 0-9 0v3.25a.75.75 0 0 1-1.5 0v-3.25a6 6 0 0 1 6-6V3a.75.75 0 0 1 .75-.75z"/>
    </svg>
  )}
  <span>{text}</span>
</span>
